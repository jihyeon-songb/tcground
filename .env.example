# Supabase (public, browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role (server-only — NEVER expose to the browser).
# Required to write RLS-deny-all price tables from the cron route / scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Korea Eximbank FX API (server-only). Used to store daily FX rows and calculate
# KRW display prices while preserving source currency/amount.
KOREA_EXIM_FX_API_KEY=

# eBay API (server-only). From your eBay developer keyset.
# EBAY_ENV: "sandbox" (default) or "production".
EBAY_ENV=production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Set to "true" only if Marketplace Insights (sold data) access is granted.
# Restricted Limited Release — usually unavailable to individual developers.
EBAY_MARKETPLACE_INSIGHTS_ENABLED=false

# eBay Marketplace account deletion/closure notification endpoint.
# Generate the token with: openssl rand -hex 32
EBAY_DELETION_VERIFICATION_TOKEN=
EBAY_DELETION_ENDPOINT=https://your-domain.com/api/ebay/account-deletion

# KREAM, 번개장터 and 중고나라 (asking / 판매중 호가)
# automated collection.
# These domestic sources have no official public API and unconfirmed reuse
# rights, so automated adapters are SCAFFOLDS gated by these flags. Keep "false"
# until a compliant access path (partner/API agreement) is confirmed; real data
# comes via the manual CSV import path meanwhile.
KREAM_COLLECTION_ENABLED=false
BUNJANG_COLLECTION_ENABLED=false
JOONGNA_COLLECTION_ENABLED=false

# Shared secret for the Vercel Cron price-collection route.
