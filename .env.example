# Supabase (public, browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role (server-only — NEVER expose to the browser).
# Required to write RLS-deny-all price tables from the cron route / scripts.
SUPABASE_SERVICE_ROLE_KEY=

# eBay API (server-only). From your eBay developer keyset.
# EBAY_ENV: "sandbox" (default) or "production".
EBAY_ENV=sandbox
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Set to "true" only if Marketplace Insights (sold data) access is granted.
# Restricted Limited Release — usually unavailable to individual developers.
EBAY_MARKETPLACE_INSIGHTS_ENABLED=false

# Shared secret for the Vercel Cron price-collection route.
CRON_SECRET=
