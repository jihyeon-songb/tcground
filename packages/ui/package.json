{
  "name": "@tcground/ui",
  "version": "0.1.2",
  "private": false,
  "description": "Reusable React UI components extracted from TCGround.",
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "tcground"
  ],
  "license": "MIT",
  "homepage": "https://github.com/jihyeon-songb/tcground#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jihyeon-songb/tcground.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/jihyeon-songb/tcground/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "pnpm --filter @tcground/headless build",
    "build": "node -e \"const fs = require('node:fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('.tsbuildinfo', { force: true })\" && tsc -p tsconfig.build.json && node -e \"const fs = require('node:fs'); fs.copyFileSync('src/theme.css', 'dist/theme.css')\"",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tcground/headless": "workspace:^",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
