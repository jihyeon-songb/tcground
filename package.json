{
  "name": "tcg-round",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:docs": "pnpm --filter @tcground/docs build",
    "build:ui": "pnpm --filter @tcground/ui build",
    "start": "next start",
    "test": "vitest",
    "collect:daily": "pnpm collect:ebay:daily; pnpm collect:kream:daily",
    "collect:ebay:daily": "node --env-file=.env.local --import tsx scripts/collect-prices.ts --browse --daily-window-size 50 --source-batch-size 25",
    "collect:kream:daily": "KREAM_COLLECTION_ENABLED=true node --env-file=.env.local --import tsx scripts/collect-kream-search-page.ts --segmented --max-scrolls 0 --query-delay-ms 750",
    "import:cards": "node --env-file=.env.local --import tsx scripts/import-cards.ts",
    "import:kr": "node --env-file=.env.local --import tsx scripts/import-pokemoncard.ts",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs": "pnpm --filter @tcground/docs start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "@tcground/ui": "^0.1.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/nextjs-vite": "^10.4.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.0",
    "playwright": "^1.49.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
